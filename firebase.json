{
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "storage": {
        "rules": "storage.rules"
    },
    "functions": {
        "source": "functions",
        "codebase": "default",
        "runtime": "nodejs20",
        "predeploy": [
            "npm --prefix \"$RESOURCE_DIR\" run build"
        ]
    },
    "apphosting": [
        {
            "backendId": "renotech-erp",
            "rootDir": "apps/erp",
            "ignore": [
                "node_modules",
                ".git",
                ".next"
            ]
        },
        {
            "backendId": "renotech-web",
            "rootDir": "apps/landing",
            "ignore": [
                "node_modules",
                ".git",
                ".astro",
                "dist"
            ]
        }
    ]
}